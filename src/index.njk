---
layout: base.njk
title: Upcoming Game Releases
---

<section class="topbar">
  <div class="container">
    <div class="topbar-inner">
      <div>
        <p class="updated-tag">Updated {{ buildTime }} · {{ games | length }} games</p>
        <h1>Upcoming Releases</h1>
      </div>
      <div class="search-sort">
        <input type="text" id="search" placeholder="Search a game..." autocomplete="off">
        <select id="sort">
          <option value="date-asc">Date ↑</option>
          <option value="date-desc">Date ↓</option>
          <option value="hype">Most Hyped</option>
        </select>
      </div>
    </div>

    <div class="filters">
      <div class="filter-group" data-filter-type="platform">
        <button class="filter-btn active" data-value="all">All</button>
        <button class="filter-btn" data-value="PC">PC</button>
        <button class="filter-btn" data-value="PS5">PS5</button>
        <button class="filter-btn" data-value="Xbox">Xbox</button>
        <button class="filter-btn" data-value="Switch">Switch</button>
      </div>
      <div class="filter-divider"></div>
      <div class="filter-group" data-filter-type="genre">
        <button class="filter-btn active" data-value="all">All genres</button>
        {% for genre in games | allGenres %}
          {% if genre !== 'Indie' %}
            <button class="filter-btn{% if loop.index > 4 %} genre-extra{% endif %}" data-value="{{ genre }}">{{ genre }}</button>
          {% endif %}
        {% endfor %}
        <button class="filter-btn genre-more-btn" id="genre-more">+more</button>
      </div>
      <div class="filter-divider"></div>
      <button class="filter-btn indie-toggle" id="indie-toggle">+ Indie</button>
    </div>
  </div>
</section>

<section class="hot-section">
  <div class="container">
    <div class="hot-head">
      <span class="hot-tag">HOT</span>
      <h2>Most Anticipated</h2>
      <div class="hot-nav">
        <button class="hot-nav-btn" id="hot-prev">&#8249;</button>
        <button class="hot-nav-btn" id="hot-next">&#8250;</button>
      </div>
    </div>
    <div class="hot-slider" id="hot-slider">
      {% for group in games | topPerMonth(5) %}
        {% for game in group.games %}
          <a href="/games/{{ game.slug }}/" class="card-link hot-slide">
            <article class="card hot-card">
              <div class="cover cover-{{ game.color }} cover-hot">
                {% if game.cover %}<img src="{{ game.cover }}" alt="{{ game.title }}" class="cover-img">{% endif %}
                <span class="rank-badge rank-{{ loop.index }}">{{ loop.index }}</span>
                <span class="hot-hype">{{ game.hype }}</span>
                <span class="hot-month-chip">{{ group.month }}</span>
              </div>
              <div class="card-body">
                <h3>{{ game.title }}</h3>
                <p class="meta">{{ game.releaseDate | dateFormat }} · {{ game.price }}</p>
                <p class="genres">{{ game.genres | join(' · ') }}</p>
                <div class="badges">
                  {% for p in game.platforms %}
                    <span class="badge badge-{{ p | lower }}">{{ p }}</span>
                  {% endfor %}
                </div>
              </div>
            </article>
          </a>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</section>

<div class="container content">
  <p id="empty-state" class="empty-state" style="display:none;">No games found with these filters.</p>

  {% for group in games | groupByMonth %}
    <section class="month-section" data-month-block>
      <div class="month-head">
        <p class="month-label">{{ group.month }}</p>
        <p class="month-count">{{ group.games | length }} games</p>
      </div>
      <div class="month-grid">
        {% for game in group.games %}
          <a href="/games/{{ game.slug }}/" class="card-link">
            <article class="card"
                     data-platforms="{{ game.platforms | join(',') }}"
                     data-genres="{{ game.genres | join(',') }}"
                     data-title="{{ game.title | lower }}"
                     data-date="{{ game.releaseDate }}"
                     data-hype="{{ game.hype }}">
              <div class="cover cover-{{ game.color }}">
                {% if game.cover %}<img src="{{ game.cover }}" alt="{{ game.title }}" class="cover-img">{% endif %}
                <div class="hype-mini">{{ game.hype }}</div>
              </div>
              <div class="card-body">
                <h3>{{ game.title }}</h3>
                <p class="meta">{{ game.releaseDate | dateFormatShort }}</p>
                <p class="genres">{{ game.genres | join(' · ') }}</p>
                <div class="badges">
                  {% for p in game.platforms %}
                    <span class="badge badge-{{ p | lower }}">{{ p }}</span>
                  {% endfor %}
                </div>
              </div>
            </article>
          </a>
        {% endfor %}
      </div>
    </section>
  {% endfor %}
</div>

<script>
  const cards = document.querySelectorAll('[data-month-block] .card');
  const monthSections = document.querySelectorAll('[data-month-block]');
  const searchInput = document.getElementById('search');
  const sortSelect = document.getElementById('sort');
  const emptyState = document.getElementById('empty-state');

  const activeFilters = { platform: 'all', genre: 'all' };
  let searchTerm = '';
  let showIndie = false; // hidden by default

  function applyFilters() {
    let visibleCount = 0;
    cards.forEach(card => {
      const platforms = card.dataset.platforms.split(',');
      const genres = card.dataset.genres.split(',');
      const title = card.dataset.title;

      const platformOk = activeFilters.platform === 'all' || platforms.includes(activeFilters.platform);
      const genreOk = activeFilters.genre === 'all' || genres.includes(activeFilters.genre);
      const searchOk = !searchTerm || title.includes(searchTerm);
      const indieOk = showIndie || !genres.includes('Indie');

      const visible = platformOk && genreOk && searchOk && indieOk;
      card.closest('a').style.display = visible ? 'block' : 'none';
      if (visible) visibleCount++;
    });

    monthSections.forEach(section => {
      const visibleCards = section.querySelectorAll('a:not([style*="display: none"]) .card');
      section.style.display = visibleCards.length > 0 ? '' : 'none';
    });

    emptyState.style.display = visibleCount === 0 ? 'block' : 'none';
  }

  function applySort() {
    const mode = sortSelect.value;
    monthSections.forEach(section => {
      const grid = section.querySelector('.month-grid');
      const links = [...grid.querySelectorAll('a')];
      links.sort((a, b) => {
        const ca = a.querySelector('.card');
        const cb = b.querySelector('.card');
        switch (mode) {
          case 'date-asc':  return new Date(ca.dataset.date) - new Date(cb.dataset.date);
          case 'date-desc': return new Date(cb.dataset.date) - new Date(ca.dataset.date);
          case 'hype':      return parseInt(cb.dataset.hype) - parseInt(ca.dataset.hype);
        }
      });
      links.forEach(l => grid.appendChild(l));
    });
  }

  // platform + genre filter groups
  document.querySelectorAll('.filter-group').forEach(group => {
    const type = group.dataset.filterType;
    group.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        group.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeFilters[type] = btn.dataset.value;
        applyFilters();
      });
    });
  });

  // genre more/less toggle
  document.getElementById('genre-more').addEventListener('click', function() {
    const open = document.querySelector('.filters').classList.toggle('genres-open');
    this.textContent = open ? '–less' : '+more';
  });

  // indie toggle
  document.getElementById('indie-toggle').addEventListener('click', function() {
    showIndie = !showIndie;
    this.classList.toggle('active', showIndie);
    this.textContent = showIndie ? '✓ Indie' : '+ Indie';
    applyFilters();
  });

  // hot slider nav
  const sliderEl = document.getElementById('hot-slider');
  document.getElementById('hot-prev').addEventListener('click', () => {
    sliderEl.scrollBy({ left: -284, behavior: 'smooth' });
  });
  document.getElementById('hot-next').addEventListener('click', () => {
    sliderEl.scrollBy({ left: 284, behavior: 'smooth' });
  });

  searchInput.addEventListener('input', e => {
    searchTerm = e.target.value.toLowerCase().trim();
    applyFilters();
  });

  sortSelect.addEventListener('change', applySort);

  // apply indie filter on initial load
  applyFilters();
</script>
