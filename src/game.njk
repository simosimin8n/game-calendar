---
layout: base.njk
pagination:
  data: games
  size: 1
  alias: game
permalink: "/games/{{ game.slug }}/"
eleventyComputed:
  title: "{{ game.title }} — Game Calendar"
---

<div class="game-detail">

  {# ── HERO ─────────────────────────────────────── #}
  <div class="gd-hero cover-{{ game.color }}">
    {% if game.cover %}<img src="{{ game.cover }}" alt="{{ game.title }}" class="cover-img">{% endif %}
    <div class="gd-hero-content container">
      <a href="/" class="gd-back">← All games</a>
      <div class="gd-hero-body">
        {% if game.hype %}<span class="hype-badge">HYPE {{ game.hype }}</span>{% endif %}
        <h1>{{ game.title }}</h1>
        <p class="gd-release">{{ game.releaseDate | dateFormat }}
          {% if game.price and game.price !== 'TBD' %} · {{ game.price }}{% endif %}
        </p>
        <div class="gd-badges">
          {% for p in game.platforms %}
            <span class="badge badge-{{ p | lower }}">{{ p }}</span>
          {% endfor %}
          {% if game.genres and game.genres.length %}
            {% for g in game.genres | slice(0, 2) %}
              <span class="gd-genre-tag">{{ g }}</span>
            {% endfor %}
          {% endif %}
        </div>
      </div>
      {% if game.url %}
        <a href="{{ game.url }}" target="_blank" rel="noopener" class="igdb-btn">IGDB ↗</a>
      {% endif %}
    </div>
  </div>

  {# ── BODY ─────────────────────────────────────── #}
  <div class="gd-body container">

    {# ── MAIN ─────────────────────────────────────── #}
    <div class="gd-main">

      {% if game.summary %}
      <section class="gd-section">
        <h2 class="gd-section-title">About</h2>
        <p class="gd-summary">{{ game.summary }}</p>
      </section>
      {% endif %}

      {% if game.youtubeId %}
      <section class="gd-section">
        <h2 class="gd-section-title">Trailer</h2>
        <div class="gd-trailer-wrap">
          <iframe
            src="https://www.youtube-nocookie.com/embed/{{ game.youtubeId }}?rel=0&modestbranding=1"
            title="{{ game.title }} — Official Trailer"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy">
          </iframe>
        </div>
      </section>
      {% endif %}

      {# Key metadata inline #}
      <section class="gd-section">
        <h2 class="gd-section-title">Details</h2>
        <dl class="gd-meta-grid">
          {% if game.developers and game.developers.length %}
          <div class="gd-meta-cell">
            <dt>{{ "Developers" if game.developers.length > 1 else "Developer" }}</dt>
            <dd>{{ game.developers | join(', ') }}</dd>
          </div>
          {% endif %}
          {% if game.publishers and game.publishers.length %}
          <div class="gd-meta-cell">
            <dt>Publisher</dt>
            <dd>{{ game.publishers | join(', ') }}</dd>
          </div>
          {% endif %}
          {% if game.genres and game.genres.length %}
          <div class="gd-meta-cell">
            <dt>Genres</dt>
            <dd>{{ game.genres | join(', ') }}</dd>
          </div>
          {% endif %}
          {% if game.themes and game.themes.length %}
          <div class="gd-meta-cell">
            <dt>Themes</dt>
            <dd>{{ game.themes | join(', ') }}</dd>
          </div>
          {% endif %}
          {% if game.gameModes and game.gameModes.length %}
          <div class="gd-meta-cell">
            <dt>Game Modes</dt>
            <dd>{{ game.gameModes | join(', ') }}</dd>
          </div>
          {% endif %}
          {% if game.playerPerspectives and game.playerPerspectives.length %}
          <div class="gd-meta-cell">
            <dt>Perspective</dt>
            <dd>{{ game.playerPerspectives | join(', ') }}</dd>
          </div>
          {% endif %}
          {% if game.collections and game.collections.length %}
          <div class="gd-meta-cell">
            <dt>Series</dt>
            <dd>{{ game.collections | join(', ') }}</dd>
          </div>
          {% endif %}
          {% if game.franchises and game.franchises.length %}
          <div class="gd-meta-cell">
            <dt>Franchise</dt>
            <dd>{{ game.franchises | join(', ') }}</dd>
          </div>
          {% endif %}
          {% if game.engine and game.engine.length %}
          <div class="gd-meta-cell">
            <dt>Engine</dt>
            <dd>{{ game.engine | join(', ') }}</dd>
          </div>
          {% endif %}
          {% if game.alternativeNames and game.alternativeNames.length %}
          <div class="gd-meta-cell">
            <dt>Also known as</dt>
            <dd>{{ game.alternativeNames | join(', ') }}</dd>
          </div>
          {% endif %}
          <div class="gd-meta-cell">
            <dt>IGDB ID</dt>
            <dd class="gd-faint">{{ game.id }}</dd>
          </div>
        </dl>
      </section>

      {% if game.similarGames and game.similarGames.length %}
      <section class="gd-section">
        <h2 class="gd-section-title">Similar Games</h2>
        <div class="gd-similar-grid">
          {% set simColors = ['teal', 'coral', 'purple', 'amber', 'pink', 'blue'] %}
          {% for sg in game.similarGames %}
          <div class="gd-similar-card cover-{{ simColors[loop.index0 % 6] }}">
            <div class="gd-similar-inner">
              <p class="gd-similar-name">{{ sg.name }}</p>
              <p class="gd-similar-meta">
                {%- if sg.genres and sg.genres.length %}{{ sg.genres[0] }}{% endif -%}
                {%- if sg.rating %} · {{ sg.rating }}{% endif -%}
              </p>
            </div>
          </div>
          {% endfor %}
        </div>
      </section>
      {% endif %}

    </div>

    {# ── SIDEBAR ──────────────────────────────────── #}
    <aside class="gd-sidebar">

      {% if game.releases and game.releases.length %}
      <section class="gd-sidebar-section">
        <h3 class="gd-sidebar-label">Releases</h3>
        <ul class="gd-releases">
          {% for r in game.releases %}
          <li>
            <span class="gd-rel-platform">{{ r.platform }}</span>
            <span class="gd-rel-date">{{ r.date }}</span>
            {% if r.region and r.region !== 'Worldwide' %}
              <span class="gd-rel-region">{{ r.region }}</span>
            {% endif %}
          </li>
          {% endfor %}
        </ul>
      </section>
      {% endif %}

      {% if game.deals and game.deals.length %}
      <section class="gd-sidebar-section">
        <h3 class="gd-sidebar-label">Best Prices</h3>
        <div class="gd-deals">
          {% for deal in game.deals %}
          <a href="{{ deal.url }}" target="_blank" rel="noopener" class="gd-deal-row">
            <span class="gd-deal-store">{{ deal.store }}</span>
            {% if deal.cut > 0 %}
              <span class="gd-deal-cut">-{{ deal.cut }}%</span>
              <span class="gd-deal-regular">${{ deal.regular }}</span>
            {% endif %}
            <span class="gd-deal-price">${{ deal.price }}</span>
            <span class="gd-deal-arrow">↗</span>
          </a>
          {% endfor %}
        </div>
        {% if game.itadUrl %}
          <a href="{{ game.itadUrl }}" target="_blank" rel="noopener"
             class="gd-link-btn" style="margin-top:0.6rem;display:inline-block;">
            All prices on ITAD ↗
          </a>
        {% endif %}
      </section>
      {% endif %}

      {% if game.websites and game.websites.length %}
      <section class="gd-sidebar-section">
        <h3 class="gd-sidebar-label">Links</h3>
        <div class="gd-links">
          {% for w in game.websites %}
          <a href="{{ w.url }}" target="_blank" rel="noopener" class="gd-link-btn">
            {%- if w.type === 'official' %}Official Site
            {%- elif w.type === 'steam' %}Steam
            {%- elif w.type === 'epic' %}Epic Games
            {%- elif w.type === 'gog' %}GOG
            {%- elif w.type === 'wikipedia' %}Wikipedia
            {%- elif w.type === 'twitter' %}Twitter / X
            {%- elif w.type === 'facebook' %}Facebook
            {%- elif w.type === 'reddit' %}Reddit
            {%- elif w.type === 'discord' %}Discord
            {%- else %}{{ w.type }}{%- endif -%}
          </a>
          {% endfor %}
        </div>
      </section>
      {% endif %}

      {% if game.ageRatings and game.ageRatings.length %}
      <section class="gd-sidebar-section">
        <h3 class="gd-sidebar-label">Age Ratings</h3>
        <div class="gd-ratings">
          {% for r in game.ageRatings %}
          <div class="gd-rating-badge">
            <span class="gd-rating-sys">{{ r.system }}</span>
            <span class="gd-rating-val">{{ r.rating }}</span>
          </div>
          {% endfor %}
        </div>
      </section>
      {% endif %}

      {% if game.languageSupports and game.languageSupports.length %}
      <section class="gd-sidebar-section">
        <h3 class="gd-sidebar-label">Languages</h3>
        <table class="gd-lang-table">
          <thead>
            <tr>
              <th>Language</th>
              <th title="Audio">🔊</th>
              <th title="Subtitles">💬</th>
              <th title="Interface">🖥</th>
            </tr>
          </thead>
          <tbody>
            {% for ls in game.languageSupports %}
            <tr>
              <td>{{ ls.language }}</td>
              <td class="gd-lang-check">{% if ls.audio %}✓{% endif %}</td>
              <td class="gd-lang-check">{% if ls.subtitles %}✓{% endif %}</td>
              <td class="gd-lang-check">{% if ls.interface %}✓{% endif %}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </section>
      {% endif %}

    </aside>

  </div>
</div>
